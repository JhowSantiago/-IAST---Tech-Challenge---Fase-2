# Base dos Dados (BigQuery) — criar projeto gratuito em https://console.cloud.google.com
BILLING_PROJECT_ID=seu-projeto-gcp

# AWS — conta já criada; preencher após criar usuário IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Buckets S3 (preencher com o Account ID da conta AWS)
BUCKET_SOR=seu-account-id-data-sor
BUCKET_SOT=seu-account-id-data-sot
BUCKET_SPEC=seu-account-id-data-spec

# Kafka local (ambiente de desenvolvimento)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
