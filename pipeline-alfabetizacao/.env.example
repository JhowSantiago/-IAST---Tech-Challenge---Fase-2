# Base dos Dados (BigQuery) — criar projeto gratuito em https://console.cloud.google.com
BILLING_PROJECT_ID=seu-projeto-gcp

# AWS — conta já criada; preencher após criar usuário IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2

# Buckets S3 — 3 buckets separados (somente o nome do bucket)
BUCKET_BRONZE=seu-account-id--tech-challenge-fase-2-bronze
BUCKET_SILVER=seu-account-id--tech-challenge-fase-2-silver
BUCKET_GOLD=seu-account-id--tech-challenge-fase-2-gold

# Kafka local (ambiente de desenvolvimento)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
